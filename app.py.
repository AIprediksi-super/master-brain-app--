import streamlit as st
import numpy as np
import easyocr
from PIL import Image
from collections import Counter

# Inisialisasi OCR (Deep Learning)
@st.cache_resource
def load_ocr():
    return easyocr.Reader(['en'])
reader = load_ocr()

st.set_page_config(page_title="Master Brain Ultra-Sim", layout="wide")
st.title("🧠 Master Brain: Ultra-Simulation Mode")

# Manajemen Riwayat & Simulasi
if 'history' not in st.session_state:
    st.session_state.history = []
if 'score' not in st.session_state:
    st.session_state.score = {'hit': 0, 'total': 0}

# Sidebar Input
st.sidebar.header("Data Entry")
input_mode = st.sidebar.selectbox("Pilih Input:", ["Upload Screenshot", "Input Manual"])

final_data = []
if input_mode == "Upload Screenshot":
    up_file = st.file_uploader("Upload Gambar:", type=["png", "jpg", "jpeg"])
    if up_file:
        img = Image.open(up_file)
        results = reader.readtext(np.array(img), detail=0)
        final_data = [str(x).upper() for x in results if len(str(x)) <= 5]
else:
    manual = st.text_input("Ketik data (pisahkan spasi):").upper()
    final_data = manual.split()

# --- MESIN ANALISIS & SIMULASI ---
def get_top_5_analysis(data):
    if len(data) < 5: return []
    last_val = data[-1]
    # Weighted Markov Logic
    weights = np.linspace(0.5, 1.0, len(data)-1)
    trans = {}
    for i in range(len(data)-1):
        if data[i] == last_val:
            nxt = data[i+1]
            trans[nxt] = trans.get(nxt, 0) + weights[i]
    
    # Bayesian Smoothing
    all_cnt = Counter(data)
    for k, v in all_cnt.items():
        trans[k] = trans.get(k, 0) + (v * 0.05)
    
    return sorted(trans.items(), key=lambda x: x[1], reverse=True)[:5]

if final_data:
    tab1, tab2 = st.tabs(["🎯 Prediksi Top 5", "📉 Mode Simulasi (Akurasi)"])
    
    with tab1:
        st.subheader("Peringkat Prediksi Saat Ini")
        top_5 = get_top_5_analysis(final_data)
        if top_5:
            cols = st.columns(5)
            for i, (res, weight) in enumerate(top_5):
                cols[i].metric(f"Rank {i+1}", res, f"{weight:.1f}")
        
        # Konfirmasi Hasil (Untuk belajar)
        st.divider()
        real_result = st.text_input("Masukkan Hasil Asli (setelah keluar):").upper()
        if st.button("Validasi & Simpan"):
            st.session_state.total_data = final_data
            is_hit = any(real_result == r for r, w in top_5)
            st.session_state.score['total'] += 1
            if is_hit: st.session_state.score['hit'] += 1
            st.session_state.history.append({"input": final_data[-5:], "top_5": [r for r, w in top_5], "real": real_result, "status": "HIT ✅" if is_hit else "MISS ❌"})
            st.success("Hasil divalidasi!")

    with tab2:
        st.subheader("Evaluasi Performa Mesin")
        acc = (st.session_state.score['hit'] / st.session_state.score['total'] * 100) if st.session_state.score['total'] > 0 else 0
        st.metric("Total Accuracy Rate", f"{acc:.2f}%")
        
        if st.session_state.history:
            st.table(st.session_state.history)

